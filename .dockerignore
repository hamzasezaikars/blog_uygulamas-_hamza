# See https://docs.docker.com/engine/reference/builder/#dockerignore-file for more about ignoring files.

# Ignore git directory and files
/.git/
/.gitignore

# Ignore bundler config.
/.bundle

# Ignore all environment files and secrets
.env*
/config/master.key
/config/credentials/*.key

# Ignore all logfiles and tempfiles
/log/*
!/log/.keep
/tmp/*
!/tmp/.keep

# Ignore pidfiles, but keep the directory
/tmp/pids/*
!/tmp/pids/.keep

# Ignore storage (uploaded files and SQLite databases)
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep

# Ignore node modules and asset build files
/node_modules/
/app/assets/builds/*
!/app/assets/builds/.keep
/public/assets

# Ignore CI and Kamal deployment files
/.github
/config/deploy*.yml
/.kamal

# Ignore development environment files
/.devcontainer

# Ignore Docker-related files
/.dockerignore
/Dockerfile*
